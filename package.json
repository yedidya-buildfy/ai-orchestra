{
  "name": "@yedidya-dan/ai-orchestra",
  "version": "0.5.0",
  "description": "Self-refreshing, token-aware multi-agent orchestration over Markdown.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yedidya-buildfy/ai-orchestra.git"
  },
  "homepage": "https://github.com/yedidya-buildfy/ai-orchestra#readme",
  "bugs": {
    "url": "https://github.com/yedidya-buildfy/ai-orchestra/issues"
  },
  "author": "yedidya-dan",
  "type": "module",
  "bin": {
    "ai-orchestra": "dist/cli.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "templates",
    "README.md",
    "LICENSE"
  ],
  "license": "MIT",
  "keywords": [
    "ai",
    "agents",
    "claude",
    "codex",
    "gemini",
    "multi-agent",
    "orchestration",
    "tmux",
    "markdown",
    "context-management"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit",
    "cli": "tsx src/cli.ts",
    "prepublishOnly": "npm run typecheck && npm test && npm run build"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@anthropic-ai/tokenizer": "^0.0.4",
    "chokidar": "^5.0.0",
    "commander": "^12.1.0",
    "js-tiktoken": "^1.0.21",
    "picomatch": "^4.0.4",
    "proper-lockfile": "^4.1.2"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "@types/picomatch": "^4.0.3",
    "@types/proper-lockfile": "^4.1.4",
    "@typescript-eslint/eslint-plugin": "^8.15.0",
    "@typescript-eslint/parser": "^8.15.0",
    "eslint": "^9.15.0",
    "tsup": "^8.3.5",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^2.1.5"
  }
}
